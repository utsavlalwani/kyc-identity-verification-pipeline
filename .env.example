# App
APP_NAME=KYC Pipeline
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kyc_pipeline
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# AWS - leave empty to use local fallback
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Loan Origination Service -- for cross-service app verification
LOAN_SERVICE_URL=http://localhost:8000
LOAN_SERVICE_TIMEOUT=5

# Feature Flags
USE_AWS_S3=False
USE_REAL_OCR=False

# File Upload Limits
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png
